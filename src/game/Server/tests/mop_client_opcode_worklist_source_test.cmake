foreach(route IN ITEMS CMSG_LOGOUT_REQUEST CMSG_LOGOUT_REQUEST_IDLE)
    set(expected_registration
        "DefC(${route}, \"${route}\", STATUS_LOGGEDIN, PROCESS_THREADUNSAFE, &WorldSession::HandleLogoutRequestOpcode);")
    string(FIND "${opcodes}" "${expected_registration}" exact_registration)
    string(REGEX MATCHALL "DefC\\(${route}," registrations "${opcodes}")
    list(LENGTH registrations registration_count)
    if(exact_registration EQUAL -1 OR NOT registration_count EQUAL 1)
        message(FATAL_ERROR "${route} must be registered exactly once to HandleLogoutRequestOpcode as STATUS_LOGGEDIN/PROCESS_THREADUNSAFE")
    endif()
endforeach()

