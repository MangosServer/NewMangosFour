    string(FIND "${opcodes}" "${expected_response_registration}" exact_response_registration)
    string(REGEX MATCHALL "DefS\\(${response}," response_registrations "${opcodes}")
    list(LENGTH response_registrations response_registration_count)
    if(exact_response_registration EQUAL -1 OR NOT response_registration_count EQUAL 1)
        message(FATAL_ERROR "${response} registration changed")
    endif()
